{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"redirects": [
		{
			"source": "/",
			"destination": "https://www.shrirambalaji.com/writing/posts",
			"permanent": true
		},
		{
			"source": "/writing",
			"destination": "https://www.shrirambalaji.com/writing/posts",
			"permanent": true
		},
		{
			"source": "/writing/series",
			"destination": "https://www.shrirambalaji.com/writing/posts",
			"permanent": true
		},
		{
			"source": "/posts/:path*",
			"destination": "https://www.shrirambalaji.com/writing/posts/:path*",
			"permanent": true
		},
		{
			"source": "/tags/:path*",
			"destination": "https://www.shrirambalaji.com/writing/tags/:path*",
			"permanent": true
		},
		{
			"source": "/series/:path*",
			"destination": "https://www.shrirambalaji.com/writing/series/:path*",
			"permanent": true
		}
	]
}
