---
import { Image } from "astro:assets";
import { render, type CollectionEntry } from "astro:content";
import FormattedDate from "../FormattedDate.astro";

interface Props {
	content: CollectionEntry<"post">;
}

const { content } = Astro.props;
const { data } = content;

const { remarkPluginFrontmatter } = await render(content);

const dateTimeOptions: Intl.DateTimeFormatOptions = {
	month: "long",
};
---

<h1 class="article-title">{data.title}</h1>
<div class="flex flex-wrap items-center gap-x-3 gap-y-2">
	<p class="article-meta">
		<FormattedDate date={data.publishDate} dateTimeOptions={dateTimeOptions} />
		<span aria-hidden="true">{" "}·{" "}</span>
		{remarkPluginFrontmatter.minutesRead}
	</p>
	{
		data.updatedDate && (
			<span class="article-updated">
				Updated <FormattedDate date={data.updatedDate} dateTimeOptions={dateTimeOptions} />
			</span>
		)
	}
</div>
{
	data.coverImage && (
		<figure class:list={["article-cover", { "article-cover--contained": data.coverImage.contain }]}>
			<Image
				src={data.coverImage.src}
				alt={data.coverImage.alt}
				class:list={[
					"article-cover__image",
					{
						"object-contain": data.coverImage.contain,
						"object-cover": !data.coverImage.contain,
						"article-cover__image--invert": data.coverImage.shouldInvert,
					},
				]}
				loading="eager"
				fetchpriority="high"
				width={800}
				height={450}
			/>
		</figure>
	)
}
{
	!!data.tags?.length && (
		<p class="article-tags">
			{data.tags.map((tag: string) => (
				<a
					class="editorial-link inline-block text-sm"
					aria-label={`View more blogs with the tag ${tag}`}
					href={`/writing/tags/${tag}`}
					data-pagefind-filter="tag"
				>
					{tag}
				</a>
			))}
		</p>
	)
}
