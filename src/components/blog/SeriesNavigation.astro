---
import type { CollectionEntry } from "astro:content";
import { getAllPosts, slugify } from "../../utils/post";

interface Props {
	post: CollectionEntry<"post">;
}

const { post } = Astro.props;

if (!post.data.series) return;

const allPosts = await getAllPosts();
const seriesPosts = allPosts
	.filter((entry) => entry.data.series === post.data.series)
	.sort((a, b) => a.data.publishDate.valueOf() - b.data.publishDate.valueOf());
const currentIndex = seriesPosts.findIndex((entry) => entry.id === post.id);
const previousPost = currentIndex > 0 ? seriesPosts[currentIndex - 1] : undefined;
const nextPost = currentIndex < seriesPosts.length - 1 ? seriesPosts[currentIndex + 1] : undefined;
---

{
	seriesPosts.length > 1 && (
		<nav class="series-navigation" aria-label={`${post.data.series} series navigation`}>
			<div class="series-navigation__header">
				<div>
					<p>Series</p>
					<h2>{post.data.series}</h2>
				</div>
				<p class="series-navigation__position">
					{currentIndex + 1} / {seriesPosts.length}
				</p>
			</div>

			<div class="series-navigation__links">
				{previousPost && (
					<a href={`/writing/posts/${previousPost.id}`}>
						<span>← Previous</span>
						<strong>{previousPost.data.title}</strong>
					</a>
				)}
				{nextPost && (
					<a class="series-navigation__next" href={`/writing/posts/${nextPost.id}`}>
						<span>Next →</span>
						<strong>{nextPost.data.title}</strong>
					</a>
				)}
			</div>

			<a
				class="editorial-link series-navigation__all"
				href={`/writing/series/${slugify(post.data.series)}`}
			>
				View the complete series
			</a>
		</nav>
	)
}
