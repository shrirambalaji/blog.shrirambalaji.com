---
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import { getAllPosts, getPostsGroupedBySeries } from "@/utils";

export const getStaticPaths = (async ({ paginate }) => {
	const allPosts = await getAllPosts();
	const groupedPosts = getPostsGroupedBySeries(allPosts);

	return paginate(groupedPosts, {
		pageSize: 10,
	});
}) satisfies GetStaticPaths;

interface Props {
	page: Page<CollectionEntry<"post">>;
}

const { page } = Astro.props as Props;
const redirectPath =
	page.currentPage === 1 ? "/writing/posts" : `/writing/posts/${page.currentPage}`;
const redirectUrl = import.meta.env.DEV
	? redirectPath
	: new URL(redirectPath, Astro.site).toString();
return Astro.redirect(redirectUrl, 308);
---
