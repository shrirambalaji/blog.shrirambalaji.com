---
import type { Page, GetStaticPaths } from "astro";
import type { CollectionEntry } from "astro:content";
import PageLayout from "@/layouts/Base";
import PostPreview from "@/components/blog/PostPreview";
import Pagination from "@/components/Paginator";
import { getAllPosts, getUniqueTags, getPostsGroupedBySeries } from "@/utils";

export const getStaticPaths = (async ({ paginate }) => {
	const allPosts = await getAllPosts();
	const groupedPosts = getPostsGroupedBySeries(allPosts);
	const uniqueTags = getUniqueTags(allPosts);
	return paginate(groupedPosts, { props: { uniqueTags }, pageSize: 10 });
}) satisfies GetStaticPaths;

interface Props {
	page: Page<CollectionEntry<"post">>;
	uniqueTags: string[];
}

const { page, uniqueTags } = Astro.props;

const meta = {
	title: page.currentPage === 1 ? "Writing" : `Writing - Page ${page.currentPage}`,
	description: "Read my collection of writing and the things that interest me",
};

const paginationProps = {
	...(page.url.prev && {
		prevUrl: {
			url: page.url.prev,
			text: `← Newer Posts`,
		},
	}),
	...(page.url.next && {
		nextUrl: {
			url: page.url.next,
			text: `Older Posts →`,
		},
	}),
};
---

<PageLayout meta={meta}>
	<section class="page-top-spaced grid gap-[0.35rem]" aria-label="Writing">
		<div>
			<section aria-label="Blog post list">
				<ul class="post-list">
					{
						page.data.map((p) => (
							<li class="post-list-item">
								<PostPreview post={p} as="h2" class="w-full" withDesc />
							</li>
						))
					}
				</ul>
				<div class="post-index-actions">
					{
						!!uniqueTags.length && (
							<p>
								Browse by{" "}
								<a class="editorial-link" href="/writing/tags">
									topic
								</a>
								.
							</p>
						)
					}
					<Pagination {...paginationProps} />
				</div>
			</section>
		</div>
	</section>
</PageLayout>
