---
import PageLayout from "@/layouts/Base";
import { getAllPosts, getUniqueTagsWithCount } from "@/utils";

const allPosts = await getAllPosts();
const allTags = getUniqueTagsWithCount(allPosts);

const meta = {
	title: "All Tags",
	description: "A list of all the topics I've written about in my posts",
};
---

<PageLayout meta={meta}>
	<section class="page-top-spaced" aria-labelledby="topics-heading">
		<h1 id="topics-heading" class="section-label">Topics</h1>
		<ul class="topic-list">
			{
				allTags.map(([tag, count]) => (
					<li>
						<a
							class="editorial-link text-sm"
							href={`/writing/tags/${tag}`}
							title={`View posts with the tag: ${tag}`}
							rel="prefetch"
						>
							{tag} <span>({count})</span>
						</a>
					</li>
				))
			}
		</ul>
	</section>
</PageLayout>
