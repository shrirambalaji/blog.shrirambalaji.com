---
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import { getAllPosts, getUniqueSeries, slugify, sortMDByDate } from "@/utils";

export const getStaticPaths = (async ({ paginate }) => {
	const allPosts = await getAllPosts();
	const allPostsByDate = sortMDByDate(allPosts);
	const uniqueSeries = getUniqueSeries(allPostsByDate);

	return uniqueSeries.flatMap((series) => {
		const filteredPosts = allPostsByDate.filter((post) => post.data.series === series);
		return paginate(filteredPosts, {
			params: { series: slugify(series) },
			pageSize: 10,
		});
	});
}) satisfies GetStaticPaths;

interface Props {
	page: Page<CollectionEntry<"post">>;
}

const { page } = Astro.props as Props;
const legacyPath = Astro.url.pathname.replace(/\/$/, "");
const redirectPath = `/writing${legacyPath}`;
const redirectUrl = import.meta.env.DEV
	? redirectPath
	: new URL(redirectPath, Astro.site).toString();
return Astro.redirect(redirectUrl, 308);
---
